# Node.js & React typical gitignore
node_modules/
# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# Dependency directories
/backend/node_modules/
/frontend/node_modules/
# Environment files
.env
.env.local
.env.development
.env.test
.env.production
# Build output
/build
/dist
/.next
/out
# Vite cache
tmp/
# OS files
.DS_Store
Thumbs.db
# IDE files
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
# npm
package-lock.json
# Yarn
yarn.lock
# Misc
*.log
